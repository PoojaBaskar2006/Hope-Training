import java.util.*;
class pattern{
    public static void main(String[] args){
        Scanner z=new Scanner(System.in);
        
        int r=z.nextInt();
        int c=z.nextInt();

        for(int i=0;i<r*c;i++){
            if(i%c==0){
                System.out.println();
            }
            System.out.print("*"+" ");
        }

    }
}
