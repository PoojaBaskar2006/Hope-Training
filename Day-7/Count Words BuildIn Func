import java.util.*;
class Count_Words{
    public static void main(String[] args){
        Scanner z=new Scanner(System.in);
        String s=z.nextLine();
        s=s.trim();
        String[] str=s.split("\\s+");
        if(s.isEmpty())
            System.out.println("0");
        else
            System.out.println(str.length);
    }
}
