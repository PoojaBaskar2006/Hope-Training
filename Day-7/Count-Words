import java.util.*;
class Count_Words{
    public static void main(String[] args){
        Scanner z=new Scanner(System.in);
        String s=z.nextLine();
        int c=0;
        boolean f=true;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)!=' '){
                if(f==true){
                    c++;
                    f=false;
                }
            }
            else{
                f=true;
            }
        }
        System.out.print(c);

    }
}
